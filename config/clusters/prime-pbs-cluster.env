# PBS cluster configuration.
# Edit values to match the exact production PBS cluster.

CLUSTER_NAME="prime-pbs-cluster"
SCHEDULER="pbs"

TEST_ACCOUNT="x-ccast-prj-tolbasel"
PBS_GROUP_LIST="x-ccast-prj-tolbasel"
PBS_QUEUE="preemptible"

DEFAULT_WALLTIME="00:50:00"
DEFAULT_MEM="1gb"
PBS_SELECT_BASIC="1:ncpus=1:mem=1gb"
PBS_SELECT_MPI="2:ncpus=2:mpiprocs=2:mem=2gb"
PBS_SELECT_OPENMP="1:ncpus=4:ompthreads=4:mem=2gb"
PBS_SELECT_HYBRID="2:ncpus=4:mpiprocs=2:ompthreads=2:mem=2gb"
PBS_SELECT_GPU="1:ncpus=4:mem=2gb:ngpus=1"
GPU_NODE_LIST="gpu0001 gpu0002 gpu0004 gpu0005 gpu0006 gpu0007 gpu0008 gpu0009 gpu0020 gpu0021 gpu0022 gpu0023 gpu0025 gpu0026 gpu0029 gpu0030 gpu0031 gpu0034 gpu0035 gpu0036 gpu0037 gpu0038 gpu0039 gpu0040 gpu0041 gpu0061 gpu0062 gpu0063"

# The user-provided PBS examples path.
EXAMPLES_ROOT="/mmfs1/projects/ccastest/examples"
EXAMPLE_SET_FILE="config/example_sets/prime-pbs-cluster.examples"
EXAMPLE_RUN_MODE="submit"   # discover or submit

REQUIRED_MODULES_FILE="config/required_modules/prime-pbs-cluster.conf"
EXPECTED_LIMITS_FILE="config/expected_limits/prime-pbs-cluster.conf"
KNOWN_ISSUES_FILE="config/known_issues/prime-pbs-cluster.conf"

# Node discovery can be changed without touching scripts.
NODE_DISCOVERY_COMMAND="freenodes -gco | tail -n +2 | grep -v -i 'offline' | awk '{print $1}'"
NODE_SCOPE="sample"            # sample or all-nodes
NODE_SAMPLE_COUNT="4"

# Workload module stacks. Keep these aligned with current module avail.
COMPILER_MODULES="gcc/15.2.0"
MPI_MODULES="openmpi/5.0.2"
OPENMP_CC="gcc"
OPENMP_CFLAGS="-fopenmp"
MPI_CC="mpicc"
HYBRID_CFLAGS="-fopenmp"
# complete module stack for heavy workloads
MODULE_HEAVY_STACK="gcc/15.2.0 openmpi/5.0.2 python/3.12.2 qe/7.4.1"

# Filesystem checks. Blank values are ignored.
CHECK_PATHS="${HOME} /tmp"
