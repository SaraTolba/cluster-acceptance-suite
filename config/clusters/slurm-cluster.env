# SLURM cluster configuration.
# Edit values to match the exact production SLURM cluster.

CLUSTER_NAME="slurm-cluster"
SCHEDULER="slurm"

TEST_ACCOUNT="x-ccast-prj-"
SLURM_ACCOUNT="x-ccast-prj-"
SLURM_PARTITION="compute"

DEFAULT_TIME="00:10:00"
DEFAULT_MEM="1G"
SLURM_BASIC_NODES="1"
SLURM_BASIC_NTASKS="1"
SLURM_MPI_NODES="2"
SLURM_MPI_NTASKS="4"
SLURM_MPI_TASKS_PER_NODE="2"
SLURM_OPENMP_NODES="1"
SLURM_OPENMP_NTASKS="1"
SLURM_OPENMP_CPUS_PER_TASK="4"
SLURM_HYBRID_NODES="2"
SLURM_HYBRID_NTASKS="4"
SLURM_HYBRID_TASKS_PER_NODE="2"
SLURM_HYBRID_CPUS_PER_TASK="2"

# Update this if SLURM examples live elsewhere.
EXAMPLES_ROOT="/mmfs1/projects/ccastest/examples"
EXAMPLE_SET_FILE="config/example_sets/slurm-cluster.examples"
EXAMPLE_RUN_MODE="discover"   # discover or submit

REQUIRED_MODULES_FILE="config/required_modules/slurm-cluster.conf"
EXPECTED_LIMITS_FILE="config/expected_limits/slurm-cluster.conf"
KNOWN_ISSUES_FILE="config/known_issues/slurm-cluster.conf"

NODE_DISCOVERY_COMMAND="sinfo -N -h -o '%N'"
NODE_SCOPE="sample"            # sample or all-nodes
NODE_SAMPLE_COUNT="4"

# Workload module stacks. Keep these aligned with current module avail.
COMPILER_MODULES="compiler/2025.3.0"
MPI_MODULES="mvapich/4.1"
OPENMP_CC="cc"
OPENMP_CFLAGS="-fopenmp"
MPI_CC="mpicc"
HYBRID_CFLAGS="-fopenmp"
MODULE_HEAVY_STACK="compiler/2025.3.0 mvapich/4.1 python/3.14.0 qe/7.5.0"

CHECK_PATHS="${HOME} /tmp"
